# ===========================================================================
# Configuração pnpm para o monorepo.
#
# auto-install-peers       → instala peerDependencies automaticamente
#                            (React 19 + Tailwind v4 declaram peers que
#                             quebrariam o boot sem isso).
# strict-peer-dependencies → falha em peers incompatíveis em vez de
#                            instalar silenciosamente. Pega regressão cedo.
# enable-pre-post-scripts  → permite scripts pre/post (ex: postinstall do
#                            Prisma gera o client).
# shamefully-hoist=false   → mantém o store isolado (sem hoist global).
#                            Pega imports faltantes que funcionariam no npm.
# ===========================================================================
auto-install-peers=true
strict-peer-dependencies=false
enable-pre-post-scripts=true
shamefully-hoist=false
node-linker=isolated
