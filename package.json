{
  "name": "agente-dt",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo do Agente DT — backend (LangGraph + Prisma) + frontend (React + Tailwind)",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "dev:backend": "pnpm --filter agente-dt-backend run dev",
    "dev:frontend": "pnpm --filter agente-dt-frontend run dev",
    "prisma:migrate": "pnpm --filter agente-dt-backend run prisma:migrate",
    "prisma:generate": "pnpm --filter agente-dt-backend run prisma:generate",
    "prisma:studio": "pnpm --filter agente-dt-backend run prisma:studio"
  }
}
