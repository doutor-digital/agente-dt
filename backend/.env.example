# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL) — usado tanto pelo Prisma quanto pelo
# Checkpointer do LangGraph (PostgresSaver). Mantemos uma única URL para
# evitar divergência entre as duas camadas de persistência.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agente_dt?schema=public"

# ---------------------------------------------------------------------------
# Kommo CRM — Long-Lived Access Token (gerado em Configurações > Integrações).
# Nunca commitar. O subdomínio identifica a conta (ex: meuespaco.kommo.com).
# ---------------------------------------------------------------------------
KOMMO_SUBDOMAIN="seu-subdominio"
KOMMO_ACCESS_TOKEN="seu-token-kommo"

# ---------------------------------------------------------------------------
# OpenAI — modelo usado pelo agente (gpt-4o-mini por padrão).
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Áudio de SAÍDA (TTS) — IA responde em voz quando o cliente manda áudio.
OPENAI_TTS_MODEL="gpt-4o-mini-tts"   # tts-1, tts-1-hd, gpt-4o-mini-tts
OPENAI_TTS_VOICE="nova"              # alloy, echo, fable, onyx, nova, shimmer
# URL pública do backend — o Kommo busca o áudio aqui. PRECISA ser alcançável
# pela internet (mesmo domínio dos webhooks; em dev, um túnel tipo ngrok).
BACKEND_PUBLIC_URL="https://seu-backend.exemplo.com"

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV="development"
LOG_LEVEL="debug"

# Origem do dashboard React (CORS).
FRONTEND_ORIGIN="http://localhost:5173"
