// ============================================================================
// schema.prisma — Modelo de dados do Agente DT (multi-tenant).
//
// LÓGICA DE ENGENHARIA
// --------------------
// O sistema é uma plataforma de IA para CRM Kommo + Meta WhatsApp Cloud,
// projetada para múltiplas consultorias ("unidades"). Cada Unit tem suas
// próprias credenciais (Kommo, OpenAI, Meta) e seu próprio Assistant da
// OpenAI. O painel é pensado pra mostrar a observabilidade do que cada
// unidade consome (chamadas LLM, tokens, custo, conversas).
//
// CAMADAS DE PERSISTÊNCIA
// -----------------------
//  1. UNIT — tenant raiz. Todo dado de execução é filho de uma Unit.
//  2. AGENTCONFIG — prompt e tools editáveis pelo painel, agora por Unit.
//  3. CONVERSATION/MESSAGE — histórico cronológico por lead (visão "chat").
//  4. EXECUTIONTRACE/EXECUTIONSTEP — feed do raciocínio (visão "console").
//  5. LLMCALL — toda chamada à LLM com tokens, custo e payloads — base do
//     painel "ByteGPT" (transparência do consumo).
//  6. CHECKPOINT (LangGraph) — gerenciado pelo PostgresSaver, NÃO declarado
//     aqui (a lib é dona). O `thread_id` continua sendo `unit-{slug}-lead-{id}`.
//
// Por que separar Conversation de ExecutionTrace?
//  - Trace = uma execução pontual do agente (uma resposta gerada).
//  - Conversation = continuidade do diálogo com o lead (várias execuções).
//  - O dashboard mostra ambos: chat por lead + execuções soltas.
//
// Por que LlmCall separado?
//  - Um trace pode disparar várias chamadas à LLM (loop ReAct).
//  - Custo/tokens são por chamada — agregamos por trace, conversa, dia, unit.
//  - Permite re-render de payload completo sem inflar o ExecutionTrace.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Unit — tenant raiz.
// ===========================================================================
// Cada consultoria é uma Unit. Identificada por `slug` (URL-safe), usada
// nos webhooks: /api/webhooks/{slug}/kommo etc.
//
// Credenciais ficam aqui em texto puro por simplicidade do MVP — em produção
// criptografar com KMS. Marcar como `secret` os campos sensíveis no front
// pra mascarar.
//
// `openaiAssistantId` é opcional. Se setado, o agente usa Assistants API;
// senão, cai pra Chat Completions com `systemPrompt` da Unit.
// ===========================================================================
model Unit {
  id   String @id @default(cuid())
  slug String @unique // ex: "instituto-trauma", usado em URLs
  name String

  isActive Boolean @default(true) @map("is_active")

  // CATEGORIA / SEGMENTO — define a "vertical" da unidade (ex: "saude",
  // "energia_solar"). O composer usa pra escolher um preset de persona
  // (nome da IA, enquadramento do segmento). NULL = persona genérica.
  // Texto livre de propósito: novas categorias entram só adicionando um
  // preset no composer, sem migration.
  category String? @map("category")

  // Kommo
  kommoSubdomain   String? @map("kommo_subdomain")
  kommoAccessToken String? @map("kommo_access_token")
  kommoSalesbotId  Int?    @map("kommo_salesbot_id")
  kommoReplyFieldId Int?   @map("kommo_reply_field_id")
  // ID do custom field "IA Pausada" (checkbox). Quando o lead tem essa
  // flag em true, o agente NÃO responde — operador humano pediu pausa.
  // Também é o field que a tool `pausar_ia` escreve.
  kommoPausedFieldId Int?  @map("kommo_paused_field_id")
  // Quando true, sendChatReply pula o Salesbot e envia direto via
  // POST /chats/{chatId}/messages. Usar quando o Salesbot está mandando
  // saudação hardcoded antes ou cortando a mensagem da IA.
  kommoBypassSalesbot Boolean @default(false) @map("kommo_bypass_salesbot")
  // Etapas do funil consideradas "Ganho/Convertido". Quando o webhook
  // recebe leads.status com um id desta lista, marcamos a Conversation
  // como convertida e disparamos o juiz LLM.
  kommoWonStatusIds Int[]   @default([]) @map("kommo_won_status_ids")

  // MODO WIDGET (handler `widget_request` do Salesbot) — alternativa ao
  // PATCH no campo "Resposta IA" + gatilho do Digital Pipeline. Quando
  // ligado, a resposta da IA é gerada E entregue pelo endpoint
  // /api/webhooks/{slug}/widget (chamado pelo passo "Widget" do Salesbot):
  // respondemos no `return_url` com execute_handlers [show…]. Elimina a
  // duplicata (não há campo pro DP reler) e o chunking truncado (balões
  // nativos numa só chamada). Por-unidade pra permitir piloto. Ver
  // widget.controller.ts + KommoClient.continueSalesbotWidget.
  kommoWidgetReplyEnabled Boolean @default(false) @map("kommo_widget_reply_enabled")
  // Client secret da integração privada do Kommo — assina o JWT que chega
  // no corpo do widget_request. NULL = validação permissiva (loga e segue),
  // útil pra destravar o piloto antes de fiar o secret.
  kommoWidgetSecret       String? @map("kommo_widget_secret")
  // ID do Salesbot novo (o que tem o passo Widget). Opcional — só logging.
  kommoWidgetSalesbotId   Int?    @map("kommo_widget_salesbot_id")

  // OpenAI — credenciais por unidade (cada uma com sua API key e assistant)
  openaiApiKey      String? @map("openai_api_key")
  // Admin key (sk-admin-...) — usada pelos endpoints /v1/organization/*
  // (costs, usage, projects). Opcional. Sem ela, o painel de Integrações
  // mostra só os números MEDIDOS por nós (LlmCall) e o ping com /v1/models.
  openaiAdminKey    String? @map("openai_admin_key")
  openaiModel       String  @default("gpt-4o-mini") @map("openai_model")
  openaiAssistantId String? @map("openai_assistant_id")
  openaiTemperature Float   @default(0) @map("openai_temperature")
  openaiMaxTokens   Int     @default(1024) @map("openai_max_tokens")
  // Amostragem avançada (alternativas/complementos à temperature).
  // topP=1 + penalties=0 reproduz o comportamento padrão (sem efeito).
  // topP: corta a "cauda" de tokens improváveis (0-1). Mexa nele OU na
  // temperature, não nos dois. frequencyPenalty/presencePenalty (-2 a 2):
  // reduzem repetição de palavras / incentivam variar de assunto.
  openaiTopP             Float @default(1) @map("openai_top_p")
  openaiFrequencyPenalty Float @default(0) @map("openai_frequency_penalty")
  openaiPresencePenalty  Float @default(0) @map("openai_presence_penalty")
  // Limite mensal em USD pra disparar alertas no painel.
  openaiMonthlyBudgetUsd Decimal @default(50) @map("openai_monthly_budget_usd") @db.Decimal(10, 2)

  // Meta WhatsApp Cloud API
  metaPhoneNumberId String? @map("meta_phone_number_id")
  metaAccessToken   String? @map("meta_access_token")
  metaVerifyToken   String? @map("meta_verify_token")
  metaAppSecret     String? @map("meta_app_secret")
  // WABA ID — necessário pra Graph API analytics (pricing_analytics,
  // template_analytics). É diferente do phone_number_id: WABA agrupa
  // várias phone numbers da mesma conta WhatsApp Business.
  metaWabaId        String? @map("meta_waba_id")
  // Limite mensal em USD pra alertas no painel (gastos cobrados pela Meta).
  metaMonthlyBudgetUsd Decimal @default(0) @map("meta_monthly_budget_usd") @db.Decimal(10, 2)

  // Prompt e configuração do agente, vivem aqui pra cada unidade ter o seu.
  // É o "base prompt" do leigo — concatenamos com os blocos das features
  // (qualificação, handoff, etc) na hora de gerar o prompt efetivo.
  systemPrompt String @default("") @map("system_prompt")

  // -------------------------------------------------------------------------
  // Wizard de configuração (features para leigos editarem sem mexer no prompt).
  // O `prompt-composer` lê esses campos e gera o systemPrompt final em runtime.
  // -------------------------------------------------------------------------

  // PERSONA — quem a IA está representando.
  personaCompanyName String? @map("persona_company_name")
  personaTone        String? @map("persona_tone")          // "casual" | "formal" | "friendly"
  personaGreeting    String? @map("persona_greeting")
  // Tamanho desejado da resposta — "curta" (1 frase) | "normal" (1-3 frases) | "detalhada" (parágrafo)
  personaResponseLength String @default("normal") @map("persona_response_length")
  // Idioma principal — usado pra forçar respostas em outro idioma quando necessário.
  // BCP-47 simplificado: "pt-BR", "en-US", "es-ES", "fr-FR".
  personaLanguage   String  @default("pt-BR") @map("persona_language")
  // Pausa em segundos antes de enviar a resposta, simulando "digitando…" humano.
  // 0 = sem pausa. Útil pra não parecer bot em mensagens curtas.
  personaResponseDelaySec Int @default(0) @map("persona_response_delay_sec")

  // EMOJI STYLE — paleta de emojis que a IA pode usar livremente nas respostas
  // (string[] de qualquer emoji) + frequência ("low" | "normal" | "high").
  // Vazio = comportamento herda do `personaTone`.
  personaEmojis         String[] @default([]) @map("persona_emojis")
  personaEmojiFrequency String   @default("normal") @map("persona_emoji_frequency")

  // FONTES — 3 documentos estruturados que entram inteiros no prompt da IA.
  // O dono da clínica edita esses 3 campos como texto livre na aba "Fontes".
  // O composer renderiza cada um como uma seção (# FATOS, # PRODUTOS, # NEGÓCIO).
  // Coexistem com a tabela KnowledgeBaseEntry (RAG vetorizado pra FAQ).
  sourcePapel    String? @map("source_papel")    @db.Text  // Fatos importantes / papel da IA / fluxo
  sourceProdutos String? @map("source_produtos") @db.Text  // Produtos, serviços, valores permitidos
  sourceNegocio  String? @map("source_negocio")  @db.Text  // Visão geral do negócio, contatos, horários

  // AUTO-QUALIFICAÇÃO (Quente/Frio).
  qualificationEnabled  Boolean @default(false) @map("qualification_enabled")
  qualificationHotTag   String  @default("Quente") @map("qualification_hot_tag")
  qualificationColdTag  String  @default("Frio") @map("qualification_cold_tag")

  // TRIAGEM — define o que a IA precisa coletar antes de avançar o lead de
  // etapa, e reforça que, quando a triagem estiver completa (ou houver
  // interesse claro), ela DEVE mover de etapa. Renderizado pelo composer como
  // bloco "# TRIAGEM E AVANÇO DE ETAPA". `triageInstructions` é o texto livre
  // (lista do que coletar) que o dono da unidade edita.
  triageEnabled      Boolean @default(false) @map("triage_enabled")
  triageInstructions String? @map("triage_instructions") @db.Text

  // HANDOFF — palavras que disparam pausar_ia automaticamente.
  handoffEnabled  Boolean  @default(false) @map("handoff_enabled")
  handoffKeywords String[] @default([]) @map("handoff_keywords")

  // PIPELINE INTENTS — mapa intent -> statusId.
  // Formato JSON: { "asked_quote": 105414495, "confirmed_order": 105414499, ... }
  pipelineIntents Json? @map("pipeline_intents")

  // COLETA DE CONTATO — quando perguntar contato proativamente.
  contactCollectionEnabled    Boolean @default(false) @map("contact_collection_enabled")
  contactCollectionAfterTurns Int     @default(3) @map("contact_collection_after_turns")

  // CUPOM DE BOAS-VINDAS — primeira mensagem do lead recebe cupom.
  welcomeCouponEnabled Boolean @default(false) @map("welcome_coupon_enabled")
  welcomeCouponMessage String? @map("welcome_coupon_message")

  // HORÁRIO COMERCIAL — fora desse intervalo, IA responde mensagem padrão.
  businessHoursEnabled  Boolean  @default(false) @map("business_hours_enabled")
  businessHoursStart    Int      @default(9) @map("business_hours_start")   // 0-23
  businessHoursEnd      Int      @default(18) @map("business_hours_end")    // 0-23
  businessHoursDays     String[] @default(["mon","tue","wed","thu","fri"]) @map("business_hours_days")
  businessHoursTimezone String   @default("America/Sao_Paulo") @map("business_hours_timezone")
  outOfHoursMessage     String?  @map("out_of_hours_message")

  // FOLLOW-UP — instruções pra IA mencionar follow-up (real scheduling fica pra depois).
  followUpEnabled    Boolean @default(false) @map("follow_up_enabled")
  followUpAfterHours Int     @default(24) @map("follow_up_after_hours")
  followUpMessage    String? @map("follow_up_message")

  // COLETA DE NOME — IA pergunta o nome do lead e atualiza o título do lead
  // no Kommo via tool `atualizar_titulo_lead`. Útil quando o lead chega
  // anônimo ("Visitante", "WhatsApp Web", etc).
  collectNameEnabled Boolean @default(false) @map("collect_name_enabled")

  // RESUMO EM CAMPO CUSTOM — quando configurado, a tool resumir_lead_para_sdr
  // grava o resumo gerado nesse custom field DO LEAD no Kommo (além da nota
  // interna que já é postada). Útil pra deixar o último resumo visível no
  // card pra o SDR humano. NULL = só nota interna (comportamento legado).
  summaryCustomFieldId   Int?    @map("summary_custom_field_id")
  summaryCustomFieldName String? @map("summary_custom_field_name")

  // COLETA DE ORIGEM — IA pergunta "como conheceu a clínica". A resposta
  // vira uma tag "Origem: <fonte>" via `aplicar_tag`. As opções abaixo
  // são oferecidas como sugestão (mas o lead pode dizer qualquer coisa).
  collectSourceEnabled Boolean  @default(false) @map("collect_source_enabled")
  collectSourceOptions String[] @default(["Instagram", "Google", "Indicação", "TikTok", "Facebook"]) @map("collect_source_options")

  // GOOGLE CALENDAR — habilita a tool `agendar_consulta` da IA.
  // Conectado via OAuth 2.0; refreshToken usado pra renovar accessToken.
  googleAccessToken       String?   @map("google_access_token")
  googleRefreshToken      String?   @map("google_refresh_token")
  googleTokenExpiresAt    DateTime? @map("google_token_expires_at")
  googleCalendarId        String?   @map("google_calendar_id")
  googleAuthorizedEmail   String?   @map("google_authorized_email")
  googleAuthorizedAt      DateTime? @map("google_authorized_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agentConfigs     AgentConfig[]
  traces           ExecutionTrace[]
  llmCalls         LlmCall[]
  conversations    Conversation[]
  messageTemplates MessageTemplate[]
  knowledgeBase    KnowledgeBaseEntry[]
  actions          UnitAction[]
  admins           User[]
  systemLogs       SystemLog[]
  leadFieldRules   LeadFieldRule[]
  leadMemories     LeadMemory[]
  whatsappCostDaily     WhatsappCostDaily[]
  whatsappTemplateDaily WhatsappTemplateDaily[]

  @@map("units")
}

// ============================================================================
// User — autenticação Google. Não armazena senha.
//
// Roles:
//  SUPER_ADMIN — vê/edita todas as units, gerencia usuários (unitId é null).
//  UNIT_ADMIN  — vê só uma unit (unitId obrigatório). Cliente final.
//
// Bootstrap "first-login-wins": se a tabela está vazia, o primeiro email
// que logar via Google vira SUPER_ADMIN. Após isso, novos logins exigem
// que o email já exista (criado por um super admin pelo painel).
// ============================================================================
enum UserRole {
  SUPER_ADMIN
  UNIT_ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  picture      String?
  role         UserRole
  unitId       String?   @map("unit_id")
  // Hash bcrypt da senha. Nullable porque os Users criados antes da virada
  // pra senha (login Google removido) ficam sem hash até o admin resetar.
  passwordHash String?   @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  unit Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([unitId])
  @@map("users")
}

// ============================================================================
// UnitAction — regras "quando → faça" configuráveis pelo dono da clínica.
//
// Cada regra tem UMA condição em PT-BR e UMA OU MAIS ações. A IA decide quando
// aplicar (matching semântico via LLM) e dispara todas as ações configuradas
// juntas, usando as tools nativas.
//
// actions (Json) é um array de { kind, params }:
//   - { kind: "add_tag",                     params: { tags: string[] } }
//   - { kind: "move_stage",                  params: { statusId: number, pipelineId?: number, statusLabel?: string } }
//   - { kind: "transfer_with_permission",    params: { includeSummary: boolean } }
//   - { kind: "transfer_without_permission", params: { includeSummary: boolean } }
//   - { kind: "summarize_to_note",           params: { focusHint?: string } }
//
// Os campos legados `actionKind` / `actionParams` ficam mantidos por
// compatibilidade — leitura cai pra eles se `actions` estiver vazio.
// Escrita sempre vai pro `actions`.
// ============================================================================

model UnitAction {
  id     String @id @default(cuid())
  unitId String @map("unit_id")
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  conditionDescription String @map("condition_description")
  /** Lista de ações que disparam juntas quando a condição bate. */
  actions              Json   @default("[]") @map("actions")
  /** @deprecated Substituído por `actions[]`. Mantido pra rollback seguro. */
  actionKind           String @default("") @map("action_kind")
  /** @deprecated Substituído por `actions[]`. Mantido pra rollback seguro. */
  actionParams         Json   @default("{}") @map("action_params")
  notes                String? @map("notes")
  enabled              Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([unitId, enabled])
  @@map("unit_actions")
}

// ===========================================================================
// LeadMemory — memória de longo prazo por lead (resumo + fatos).
// ===========================================================================
// "Memória" do paciente que persiste entre turnos e conversas, lida pelo
// composer SEM custo extra significativo (1 query indexada por unitId+leadId)
// e atualizada em BACKGROUND após cada turno via LLM-mini barato.
//
// Modelagem:
//   - summary: parágrafo curto (≤ 600 chars) descrevendo quem é o paciente,
//     queixa, contexto-chave. Vai pro system prompt.
//   - facts:   chave→valor estruturado pra dados específicos que valem mais
//     como par do que como texto livre (ex: { idade: 35, dor_localizada: "joelho direito" }).
//   - turnsSinceUpdate: counter pra throttle do updater (só re-resume a cada N turnos).
//
// Performance: leitura O(1) com índice único. Escrita NUNCA bloqueia a
// resposta ao paciente (fire-and-forget). LLM updater roda só de N em N turnos.
// ===========================================================================
model LeadMemory {
  id     String @id @default(cuid())
  unitId String @map("unit_id")
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  /** ID do lead no Kommo. Único por unit — cada paciente tem 1 memória. */
  leadId String @map("lead_id")

  summary          String  @default("") @db.Text
  facts            Json    @default("{}") @map("facts")
  /** Quantas mensagens novas o paciente mandou desde o último resumo. */
  turnsSinceUpdate Int     @default(0) @map("turns_since_update")
  /** Última vez que o updater rodou (não a última leitura). */
  lastSummarizedAt DateTime? @map("last_summarized_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([unitId, leadId])
  @@map("lead_memories")
}

// ===========================================================================
// GlobalAction — regras "quando → faça" que valem pra TODAS as units.
// ===========================================================================
// Espelho de UnitAction sem unitId. O composer injeta as globais ANTES das
// regras da unit no system prompt, sob o título "REGRAS GLOBAIS DA PLATAFORMA".
//
// Gerenciado só por super-admin. Casos de uso: handoff humano, acolhimento
// de emergência (CVV 188), pausa em caso de ofensa, anti-diagnóstico.
//
// "ações específicas da unit" continuam em UnitAction — globais NÃO removem
// nem sobrescrevem, só somam.
// ===========================================================================
model GlobalAction {
  id String @id @default(cuid())

  conditionDescription String  @map("condition_description")
  /** Mesma estrutura de UnitAction.actions: [{ kind, params }, ...]. */
  actions              Json    @default("[]") @map("actions")
  notes                String? @map("notes")
  enabled              Boolean @default(true)
  /** Ordem de exibição/aplicação no prompt. Globais com `priority` menor vêm primeiro. */
  priority             Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled, priority])
  @@map("global_actions")
}

// ===========================================================================
// MessageTemplate — respostas prontas que a IA pode usar.
// ===========================================================================
// Cada template tem palavras-chave de gatilho. O composer inclui a lista no
// system prompt instruindo a IA a usar essas respostas quando detectar
// algum dos gatilhos na mensagem do cliente.
// ===========================================================================
model MessageTemplate {
  id              String   @id @default(cuid())
  unitId          String   @map("unit_id")
  name            String
  triggerKeywords String[] @default([]) @map("trigger_keywords")
  response        String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, name])
  @@index([unitId])
  @@map("message_templates")
}

// ===========================================================================
// KnowledgeBaseEntry — base de conhecimento da Unit (RAG).
// ===========================================================================
// Cada entry tem pergunta + resposta. O composer faz busca semântica
// (cosine similarity sobre embeddings) e injeta as top-3 mais relevantes
// no system prompt. Diferente de MessageTemplate: aqui é "conhecimento de
// domínio" (preços, endereço, horário, política), não respostas prontas.
//
// `embedding` é o vetor de 1536 dimensões do OpenAI text-embedding-3-small,
// computado quando entry é criada/editada. Busca é in-memory (cosine sim)
// até 10K entradas por Unit — pra escalar, migrar pra pgvector.
// ===========================================================================
model KnowledgeBaseEntry {
  id        String   @id @default(cuid())
  unitId    String   @map("unit_id")
  question  String   @db.Text
  answer    String   @db.Text
  embedding Float[]  @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("knowledge_base_entries")
}

// ===========================================================================
// ExecutionTrace
// ===========================================================================
model ExecutionTrace {
  id           String      @id @default(cuid())
  unitId       String?     @map("unit_id")
  threadId     String      @map("thread_id")
  leadId       String      @map("lead_id")
  channel      String      @default("kommo") // kommo | salesbot | meta | manual
  input        Json
  iaDecision   Json?       @map("ia_decision")
  latencyMs    Int?        @map("latency_ms")
  status       TraceStatus @default(RUNNING)
  errorMessage String?     @map("error_message")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  steps      ExecutionStep[]
  llmCalls   LlmCall[]
  unit       Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  systemLogs SystemLog[]

  @@index([unitId])
  @@index([threadId])
  @@index([leadId])
  @@index([createdAt(sort: Desc)])
  @@map("execution_traces")
}

// ===========================================================================
// ExecutionStep — feed visual do dashboard (uma linha por nó/tool/ação).
// ===========================================================================
model ExecutionStep {
  id        String   @id @default(cuid())
  traceId   String   @map("trace_id")
  sequence  Int
  kind      StepKind
  title     String
  payload   Json?
  latencyMs Int?     @map("latency_ms")
  createdAt DateTime @default(now()) @map("created_at")

  trace ExecutionTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@unique([traceId, sequence])
  @@index([traceId])
  @@map("execution_steps")
}

enum TraceStatus {
  RUNNING
  SUCCESS
  FAILED
}

// Tipos de step renderizados no console "AgentGPT":
//  WEBHOOK_RECEIVED — payload chegou
//  THINKING         — LLM raciocinando (chamada ao modelo)
//  TOOL_CALL        — agente decidiu chamar uma tool
//  TOOL_RESULT      — tool respondeu
//  KOMMO_ACTION     — ação efetivada no Kommo (addTag/moveStage)
//  META_ACTION      — mensagem enviada via Meta WhatsApp Cloud
//  COMPLETED        — encerramento
//  ERROR            — falha em algum nó
enum StepKind {
  WEBHOOK_RECEIVED
  THINKING
  TOOL_CALL
  TOOL_RESULT
  KOMMO_ACTION
  META_ACTION
  COMPLETED
  ERROR
}

// ===========================================================================
// SystemLog — logs estruturados (warn+) persistidos para o painel "Erros".
// ===========================================================================
// Captura automática via hook do Pino em backend/src/lib/logger.ts:
// todo logger.warn/error/fatal é gravado aqui de forma fire-and-forget,
// sem mudar callsites. Stdout continua intacto pra dev e agregadores.
//
// `module` identifica a origem (ex: "kommo.service", "webhook.controller").
// `context` é o objeto livre que vai como primeiro arg do Pino — fica
// inteiro pra inspeção no painel.
//
// `traceId` e `unitId` são nullable porque nem todo log nasce dentro de
// uma execução (ex: erro de boot, erro de auth global). Quando presentes,
// permitem drill-down: do erro pro trace pro lead.
// ===========================================================================
model SystemLog {
  id        String      @id @default(cuid())
  level     LogLevel
  module    String?
  msg       String
  context   Json?
  unitId    String?     @map("unit_id")
  traceId   String?     @map("trace_id")
  createdAt DateTime    @default(now()) @map("created_at")

  unit  Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  trace ExecutionTrace? @relation(fields: [traceId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([level])
  @@index([unitId])
  @@index([module])
  @@map("system_logs")
}

enum LogLevel {
  WARN
  ERROR
  FATAL
}

// ===========================================================================
// LeadFieldRule — captura de dados pra um custom field específico do Kommo.
// ===========================================================================
// Cada regra vira UMA tool dinâmica no agente. Quando o paciente disser
// um dado relevante, a IA chama a tool e o valor vai pro field do Kommo.
//
// Exemplo: rule {
//   kommoFieldId: 12345,
//   kommoFieldName: "Idade",
//   kommoFieldType: "numeric",
//   toolName: "salvar_idade",
//   instruction: "Quando o paciente disser a idade dele, salve aqui.",
//   valueHint: "Número inteiro entre 0 e 120.",
//   examples: ["Tenho 34 anos", "vou fazer 50", "tenho 28"],
// }
// → vira a tool `salvar_idade(leadId, idade: number)` que faz PATCH no field.
//
// `kommoFieldEnums` cachea as opções de select/multiselect [{id, value}] pra
// não bater na API toda vez. Refresh manual quando o usuário editar a regra
// (o controller refaz o lookup).
//
// `examples` ajuda a IA a reconhecer variações de frase — vai parar no prompt.
// ===========================================================================
model LeadFieldRule {
  id              String   @id @default(cuid())
  unitId          String   @map("unit_id")
  kommoFieldId    Int      @map("kommo_field_id")
  kommoFieldName  String   @map("kommo_field_name")
  kommoFieldType  String   @map("kommo_field_type") // text|textarea|numeric|date|birthday|select|multiselect|radiobutton
  kommoFieldEnums Json?    @map("kommo_field_enums") // [{id, value}] pra select/multiselect
  toolName        String   @map("tool_name")        // ex: "salvar_idade"
  instruction     String                              // quando o agente deve chamar a tool
  valueHint       String?  @map("value_hint")       // formato esperado (ex: "número inteiro 0-120")
  examples        String[] @default([])
  enabled         Boolean  @default(true)
  // Quando true, a tool gerada por esta regra ALÉM de gravar no campo custom
  // também atualiza o `name` do lead (o título visível do card no Kommo).
  // Caso de uso: regra "Nome da pessoa" — antes morava no toggle dedicado
  // collectNameEnabled, agora é por-regra.
  updatesLeadTitle Boolean @default(false) @map("updates_lead_title")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, toolName])
  @@index([unitId, enabled])
  @@map("lead_field_rules")
}

// ===========================================================================
// Conversation / Message — visão "chat" agrupada por lead.
// ===========================================================================
// O ExecutionTrace é por execução; aqui temos um registro contínuo das
// trocas de mensagens com cada paciente. Cada Message guarda o `traceId`
// se foi gerada por execução do agente (resposta de IA), permitindo
// "drill-down" pro console de raciocínio.
//
// `channel` distingue origem: kommo (chat nativo Kommo), meta (WhatsApp
// Cloud direto), manual (quando um operador respondeu pelo painel).
// ===========================================================================
model Conversation {
  id          String   @id @default(cuid())
  unitId      String   @map("unit_id")
  leadId      String   @map("lead_id")
  contactName String?  @map("contact_name")
  phone       String?
  channel     String   @default("kommo")
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Marca de conversão. `convertedAt` é NULL enquanto o lead não entrou
  // numa etapa de "Ganho". `convertedStatusId` é o status_id do Kommo
  // no momento da conversão (1 lead pode ter mais de uma etapa "ganho").
  convertedAt       DateTime? @map("converted_at")
  convertedStatusId Int?      @map("converted_status_id")

  unit         Unit                     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  messages     Message[]
  evaluations  ConversationEvaluation[]

  @@unique([unitId, leadId])
  @@index([unitId])
  @@index([lastMessageAt(sort: Desc)])
  @@index([convertedAt(sort: Desc)])
  @@map("conversations")
}

// role: "user" (paciente) | "assistant" (IA) | "system" (nota interna)
model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  traceId        String?  @map("trace_id")
  role           String
  content        String   @db.Text
  meta           Json?
  // Flagged: operador marcou esta resposta da IA como ruim (exemplo a evitar).
  // O composer inclui as últimas N flaggadas como "examples to avoid" no prompt.
  flagged        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@index([flagged])
  @@map("messages")
}

// ===========================================================================
// LlmCall — toda chamada à LLM (OpenAI/ByteGPT) é registrada aqui.
// ===========================================================================
// Esta tabela alimenta o painel "ByteGPT/IA": custo por unidade, tokens
// gastos, latência, payloads completos pra debug. Independente do trace
// (um trace pode ter N llmCalls), e independente de tool calls.
//
// `requestBody` e `responseBody` são JSON cru — útil em debug, custoso em
// storage. Considere TTL (ex: 90 dias) ou particionamento em produção.
//
// `costUsd` é calculado em runtime via tabela de preços (services/openai.service.ts).
// ===========================================================================
model LlmCall {
  id               String   @id @default(cuid())
  unitId           String?  @map("unit_id")
  traceId          String?  @map("trace_id")
  provider         String   @default("openai") // openai | bytegpt | ...
  model            String
  endpoint         String   @default("chat.completions") // chat.completions | assistants
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  costUsd          Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  latencyMs        Int      @default(0) @map("latency_ms")
  status           String   @default("success") // success | error
  errorMessage     String?  @map("error_message")
  requestBody      Json?    @map("request_body")
  responseBody     Json?    @map("response_body")
  createdAt        DateTime @default(now()) @map("created_at")

  unit  Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  trace ExecutionTrace? @relation(fields: [traceId], references: [id], onDelete: SetNull)

  @@index([unitId])
  @@index([traceId])
  @@index([createdAt(sort: Desc)])
  @@map("llm_calls")
}

// ===========================================================================
// ConversationEvaluation — LLM-as-judge sobre conversas convertidas.
// ===========================================================================
// Cada conversa convertida vira UMA avaliação (cacheamos — re-rodar custa
// dinheiro). `promptHash` é sha256 do `Unit.systemPrompt` exato usado no
// momento da conversão; é a CHAVE de agrupamento do painel "Prompts" —
// mostra qual versão do prompt gerou quais conversões com que qualidade.
//
// `scores` é um JSON com critérios pontuados 0-10. Hoje:
//   { clareza, empatia, objecoes, cta, tom, overall }
// `verdict` é o resumo qualitativo curto (1-3 parágrafos).
// `promptSnapshot` guarda o conteúdo do prompt no momento — assim mesmo
// que o Unit.systemPrompt mude depois, conseguimos reconstruir a versão.
// ===========================================================================
model ConversationEvaluation {
  id              String   @id @default(cuid())
  conversationId  String   @map("conversation_id")
  unitId          String   @map("unit_id")
  promptHash      String   @map("prompt_hash")
  promptSnapshot  String   @map("prompt_snapshot") @db.Text
  model           String
  scores          Json
  overallScore    Float    @default(0) @map("overall_score")
  verdict         String   @db.Text
  costUsd         Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  latencyMs       Int      @default(0) @map("latency_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId])
  @@index([unitId])
  @@index([promptHash])
  @@index([createdAt(sort: Desc)])
  @@map("conversation_evaluations")
}

// ===========================================================================
// AgentConfig — prompt + tools editáveis pelo dashboard.
// ===========================================================================
// Continua existindo, mas agora opcional por Unit. Se a Unit tiver um
// AgentConfig ativo, ele tem prioridade sobre os defaults da Unit.
// Se não tiver, usamos os campos `systemPrompt`/`openaiModel`/etc da própria
// Unit.
//
// O array `workflow` (legado) foi REMOVIDO em favor da aba "Ações" (UnitAction).
// ===========================================================================
model AgentConfig {
  id           String   @id @default(cuid())
  unitId       String?  @map("unit_id")
  name         String   @default("default")
  isActive     Boolean  @default(false) @map("is_active")
  systemPrompt String   @map("system_prompt")
  tools        Json     @default("[]")
  model        String   @default("gpt-4o-mini")
  temperature  Float    @default(0)
  maxTokens    Int      @default(1024) @map("max_tokens")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  unit Unit? @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([unitId])
  @@map("agent_configs")
}

// ===========================================================================
// WhatsappCostDaily — snapshot diário de custo da Meta WhatsApp Cloud API.
// ===========================================================================
// Populado por sync diário (cron) que chama /v25.0/{WABA_ID}/pricing_analytics
// na Graph API. Cada linha representa um bucket DAILY agrupado por categoria
// de cobrança (MARKETING/UTILITY/AUTHENTICATION/SERVICE/...), tipo (REGULAR /
// FREE_ENTRY_POINT / FREE_CUSTOMER_SERVICE), país, número de telefone e tier
// de volume.
//
// `costUsd` vem em USD direto da Meta (campo `cost` da resposta). `currency`
// fica como "USD" mas guardamos por segurança caso a Meta mude no futuro.
// `volume` é a contagem de mensagens cobradas naquela combinação.
//
// CHAVE LÓGICA: (unitId, date, pricingCategory, pricingType, country,
// phoneNumber, tier) — unique pra permitir upsert idempotente. NULL em
// country/phoneNumber/tier significa "dimensão não retornada/agregada".
// ===========================================================================
model WhatsappCostDaily {
  id              String   @id @default(cuid())
  unitId          String   @map("unit_id")
  /** Dia do bucket (UTC), truncado a 00:00:00. */
  date            DateTime @db.Date
  /** MARKETING | UTILITY | AUTHENTICATION | SERVICE | AUTHENTICATION_INTERNATIONAL | etc. */
  pricingCategory String   @map("pricing_category")
  /** REGULAR | FREE_ENTRY_POINT | FREE_CUSTOMER_SERVICE | FREE_GROUP_CUSTOMER_SERVICE */
  pricingType     String   @default("REGULAR") @map("pricing_type")
  /** ISO 3166-1 alpha-2 (ex: "BR", "US"). String vazia = agregado/desconhecido. */
  country         String   @default("")
  /** Phone number id da Meta. String vazia = agregado por WABA inteira. */
  phoneNumber     String   @default("") @map("phone_number")
  /** Tier de volume cobrado (string opaca da Meta). String vazia = N/A. */
  tier            String   @default("")
  /** Contagem de mensagens cobradas neste bucket. */
  volume          Int      @default(0)
  /** Custo total em USD (Meta cobra em USD; campo numérico-fixo). */
  costUsd         Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  /** Moeda originária reportada pela Meta (sempre "USD" hoje). */
  currency        String   @default("USD")
  /** Quando o sync rodou pela última vez pra esta combinação. */
  syncedAt        DateTime @default(now()) @map("synced_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date, pricingCategory, pricingType, country, phoneNumber, tier], map: "whatsapp_cost_daily_uniq")
  @@index([unitId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@map("whatsapp_cost_daily")
}

// ===========================================================================
// WhatsappTemplateDaily — snapshot diário de métricas de template.
// ===========================================================================
// Populado pelo mesmo sync chamando /v25.0/{WABA_ID}/template_analytics.
// Cada linha = um template em um dia. Inclui funil de entrega (SENT,
// DELIVERED, READ, CLICKED) + custo agregado quando a Meta retorna.
//
// `templateId` é o ID literal do template na Meta. `templateName` e
// `language` ficam denormalizados pra UI não precisar de outra tabela.
// ===========================================================================
model WhatsappTemplateDaily {
  id           String   @id @default(cuid())
  unitId       String   @map("unit_id")
  /** Dia do bucket (UTC), truncado a 00:00:00. */
  date         DateTime @db.Date
  /** ID do template na Meta (numérico em string). */
  templateId   String   @map("template_id")
  /** Nome legível do template. Desnormalizado da lista de templates. */
  templateName String?  @map("template_name")
  /** Código do idioma (pt_BR, en_US, ...). String vazia = não-segmentado. */
  language     String   @default("") @map("language")
  sent         Int      @default(0)
  delivered    Int      @default(0)
  read         Int      @default(0)
  clicked      Int      @default(0)
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  currency     String   @default("USD")
  syncedAt     DateTime @default(now()) @map("synced_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date, templateId, language], map: "whatsapp_template_daily_uniq")
  @@index([unitId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@map("whatsapp_template_daily")
}

